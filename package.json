{
  "name": "rtpsctaxplatform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "workers/*",
    "pipelines/*",
    "engines/*"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "lint": "./scripts/lint.sh",
    "test": "./scripts/test.sh",
    "build": "./scripts/build.sh",
    "start": "./scripts/start.sh",
    "start:gateway": "npm run -w @rtp/api-gateway start",
    "start:refund-status": "npm run -w @rtp/refund-status-service start",
    "start:transcript": "npm run -w @rtp/transcript-service start",
    "start:analytics": "npm run -w @rtp/analytics-service start",
    "worker:tds": "npm run -w @rtp/tds-worker start -- --once",
    "worker:transcript-pull": "npm run -w @rtp/transcript-pull-worker start -- --once",
    "worker:live-source": "npm run -w @rtp/live-source-fetcher start -- --once"
  },
  "engines": {
    "node": ">=22"
  }
}
